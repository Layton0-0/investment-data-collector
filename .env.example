# =============================================================================
# investment-data-collector 환경 변수
# =============================================================================
# .env 파일은 저장소에 커밋하지 않음. 이 프로젝트 루트에 .env 생성 후 키 설정.
# 로컬 실행: app.py 기동 시 load_dotenv()로 이 .env 자동 로드 (DART, SEC, KRX 등).
# Docker: docker-compose.local-full.yml 에서 env_file 로 이 .env 주입.
# =============================================================================

# ----- Spring 연동 (수집 데이터 전송) -----
SPRING_BASE_URL=http://localhost:8080
DATA_COLLECTION_INTERNAL_KEY=

# ----- Open DART (금융감독원 공시) -----
DART_API_KEY=
DART_BASE_URL=https://opendart.fss.or.kr/api
DART_COLLECT_DAYS=3

# ----- SEC EDGAR (유니버스: SEC_CIKS 미설정 시 company_tickers 기반) -----
SEC_USER_AGENT=InvestmentChoi/1.0 (SEC EDGAR; your-email@example.com)
SEC_API_KEY=
SEC_BASE_URL=https://data.sec.gov
SEC_COLLECT_DAYS=7
# SEC_UNIVERSE= top100 | top200 | top500 (기본 top200). 매 실행 시 SEC에서 최신 company_tickers 수신 후 상위 N개 사용. SEC_CIKS 있으면 무시
# SEC_CIKS= (선택) 고정 CIK 목록. 있으면 SEC_UNIVERSE 무시(매일 갱신 없음)

# ----- KRX Open API (한국 시세, 수집기에서 사용 시) -----
KRX_AUTH_KEY=
KRX_BASE_URL=https://openapi.krx.co.kr

# ----- 스케줄 (1 이면 기동 시 DART/SEC / 뉴스 주기 수집) -----
SCHEDULE_DART_SEC=0
SCHEDULE_SPEED_BUZZ=0
